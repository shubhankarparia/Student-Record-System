<!-- views/teacher/attendance.ejs -->

<div class="page-header">

  <div>

    <h2 class="page-title">
      <i class="fa-solid fa-calendar-check text-warning"></i>
      Attendance Management
    </h2>

    <p class="page-subtitle">
      Subject:
      <span class="text-primary fw-semibold">
        <%= subject.subject_name %>
      </span>
    </p>

  </div>

  <a href="/teacher/dashboard" class="btn btn-outline-secondary btn-pill">

    <i class="fa-solid fa-arrow-left"></i>

    Back

  </a>

</div>

<!-- SUCCESS MESSAGE -->
<% if (success) { %>

  <div class="alert alert-success">

    <i class="fa-solid fa-circle-check"></i>

    <span><%= success %></span>

  </div>

<% } %>

<!-- ERROR MESSAGE -->
<% if (error) { %>

  <div class="alert alert-danger">

    <i class="fa-solid fa-circle-exclamation"></i>

    <span><%= error %></span>

  </div>

<% } %>

<!-- MAIN CARD -->
<div class="card shadow-sm border-0 rounded-4">

  <div class="card-body p-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">

      <div>

        <h4 class="fw-bold mb-1">

          <i class="fa-solid fa-users text-primary"></i>

          Student Attendance Roster

        </h4>

        <p class="text-muted small mb-0">

          Record daily attendance status for enrolled students.

        </p>

      </div>

      <div class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">

        Total Students:
        <strong><%= students.length %></strong>

      </div>

    </div>

    <!-- FORM -->
    <form action="/teacher/attendance/<%= subject.id %>" method="POST">

      <!-- DATE -->
      <div class="row mb-4">

        <div class="col-md-4">

          <label class="form-label fw-semibold">

            Attendance Date

          </label>

          <input
            type="date"
            name="date"
            class="form-control"
            value="<%= date %>"
            required
          >

        </div>

      </div>

      <% if (students.length === 0) { %>

        <!-- EMPTY STATE -->
        <div class="text-center py-5">

          <i class="fa-solid fa-user-xmark fa-4x text-muted mb-3"></i>

          <h4 class="fw-bold">

            No Students Found

          </h4>

          <p class="text-muted">

            No students are enrolled in this course yet.

          </p>

        </div>

      <% } else { %>

        <!-- TABLE -->
        <div class="table-responsive">

          <table class="table table-hover align-middle">

            <thead class="table-light">

              <tr>

                <th style="min-width: 250px;">

                  Student Details

                </th>

                <th class="text-center">

                  Attendance Status

                </th>

              </tr>

            </thead>

            <tbody>

              <% students.forEach(s => { %>

                <% const activeStatus = attendanceMap[s.id] || 'Present' %>

                <tr>

                  <!-- STUDENT -->
                  <td>

                    <div class="fw-semibold">

                      <%= s.name %>

                    </div>

                    <div class="text-muted small">

                      <i class="fa-solid fa-envelope"></i>

                      <%= s.email %>

                    </div>

                  </td>

                  <!-- STATUS -->
                  <td>

                    <div class="d-flex flex-wrap justify-content-center gap-3">

                      <!-- PRESENT -->
                      <label class="attendance-option">

                        <input
                          type="radio"
                          name="attendance[<%= s.id %>]"
                          value="Present"
                          <%= activeStatus === 'Present' ? 'checked' : '' %>
                        >

                        <span class="badge bg-success px-3 py-2 rounded-pill">

                          Present

                        </span>

                      </label>

                      <!-- ABSENT -->
                      <label class="attendance-option">

                        <input
                          type="radio"
                          name="attendance[<%= s.id %>]"
                          value="Absent"
                          <%= activeStatus === 'Absent' ? 'checked' : '' %>
                        >

                        <span class="badge bg-danger px-3 py-2 rounded-pill">

                          Absent

                        </span>

                      </label>

                      <!-- LATE -->
                      <label class="attendance-option">

                        <input
                          type="radio"
                          name="attendance[<%= s.id %>]"
                          value="Late"
                          <%= activeStatus === 'Late' ? 'checked' : '' %>
                        >

                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">

                          Late

                        </span>

                      </label>

                      <!-- EXCUSED -->
                      <label class="attendance-option">

                        <input
                          type="radio"
                          name="attendance[<%= s.id %>]"
                          value="Excused"
                          <%= activeStatus === 'Excused' ? 'checked' : '' %>
                        >

                        <span class="badge bg-secondary px-3 py-2 rounded-pill">

                          Excused

                        </span>

                      </label>

                    </div>

                  </td>

                </tr>

              <% }) %>

            </tbody>

          </table>

        </div>

        <!-- SUBMIT -->
        <div class="mt-4">

          <button
            type="submit"
            class="btn btn-primary btn-lg w-100 rounded-pill"
          >

            <i class="fa-solid fa-cloud-arrow-up me-2"></i>

            Save Attendance Record

          </button>

        </div>

      <% } %>

    </form>

  </div>

</div>

<!-- CUSTOM STYLE -->
<style>

  .attendance-option {
    cursor: pointer;
    user-select: none;
  }

  .attendance-option input[type="radio"] {
    display: none;
  }

  .attendance-option span {
    transition: all 0.2s ease;
  }

  .attendance-option input[type="radio"]:checked + span {
    transform: scale(1.05);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
  }

</style>