<!-- views/teacher/dashboard.ejs -->

<div class="container-fluid py-4">

  <!-- PAGE HEADER -->
  <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center mb-4">
    
    <div>
      <h2 class="fw-bold mb-2">
        <i class="fa-solid fa-chalkboard-user text-primary me-2"></i>
        Teacher Dashboard
      </h2>

      <p class="text-muted mb-0">
        Welcome back,
        <span class="fw-semibold text-dark">
          <%= user.name %>
        </span>
        — manage attendance, marks, and academic activities.
      </p>
    </div>

  </div>

  <!-- STATS CARDS -->
  <div class="row g-4 mb-5">

    <!-- Students Card -->
    <div class="col-md-6 col-xl-4">

      <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">

        <div class="card-body p-4">

          <div class="d-flex justify-content-between align-items-center">

            <div>

              <p class="text-uppercase text-muted fw-semibold small mb-2">
                Total Students
              </p>

              <h2 class="fw-bold mb-0">
                <%= studentCount %>
              </h2>

            </div>

            <div
              class="d-flex align-items-center justify-content-center rounded-circle bg-primary bg-opacity-10"
              style="width: 70px; height: 70px;"
            >
              <i class="fa-solid fa-users fa-2x text-primary"></i>
            </div>

          </div>

        </div>

      </div>

    </div>

    <!-- Subjects Card -->
    <div class="col-md-6 col-xl-4">

      <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">

        <div class="card-body p-4">

          <div class="d-flex justify-content-between align-items-center">

            <div>

              <p class="text-uppercase text-muted fw-semibold small mb-2">
                Active Subjects
              </p>

              <h2 class="fw-bold mb-0">
                <%= subjects.length %>
              </h2>

            </div>

            <div
              class="d-flex align-items-center justify-content-center rounded-circle bg-success bg-opacity-10"
              style="width: 70px; height: 70px;"
            >
              <i class="fa-solid fa-book-open fa-2x text-success"></i>
            </div>

          </div>

        </div>

      </div>

    </div>

    <!-- Teacher Panel Card -->
    <div class="col-md-12 col-xl-4">

      <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">

        <div class="card-body p-4">

          <div class="d-flex justify-content-between align-items-center">

            <div>

              <p class="text-uppercase text-muted fw-semibold small mb-2">
                Faculty Access
              </p>

              <h5 class="fw-bold mb-1">
                Academic Control Panel
              </h5>

              <p class="text-muted small mb-0">
                Manage grades & attendance efficiently.
              </p>

            </div>

            <div
              class="d-flex align-items-center justify-content-center rounded-circle bg-warning bg-opacity-10"
              style="width: 70px; height: 70px;"
            >
              <i class="fa-solid fa-user-check fa-2x text-warning"></i>
            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

  <!-- SUBJECT SECTION -->
  <div class="d-flex align-items-center justify-content-between mb-4">

    <div>

      <h3 class="fw-bold mb-1">
        <i class="fa-solid fa-book-bookmark text-primary me-2"></i>
        Assigned Subjects
      </h3>

      <p class="text-muted mb-0">
        Access your subjects and manage academic activities.
      </p>

    </div>

  </div>

  <!-- EMPTY STATE -->
  <% if (subjects.length === 0) { %>

    <div class="card border-0 shadow-sm rounded-4">

      <div class="card-body text-center py-5">

        <i class="fa-solid fa-folder-open fa-4x text-secondary mb-4"></i>

        <h4 class="fw-bold mb-3">
          No Subjects Assigned
        </h4>

        <p class="text-muted mx-auto" style="max-width: 550px;">

          Your account currently has no assigned subjects.
          Please contact the system administrator to allocate courses.

        </p>

      </div>

    </div>

  <% } else { %>

    <!-- SUBJECT CARDS -->
    <div class="row g-4">

      <% subjects.forEach(sub => { %>

        <div class="col-lg-6 col-xl-4">

          <div class="card border-0 shadow-sm rounded-4 h-100 subject-card">

            <div class="card-body p-4 d-flex flex-column">

              <!-- Badge -->
              <div class="mb-3">

                <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">
                  <%= sub.course_name %>
                </span>

              </div>

              <!-- Subject Name -->
              <h4 class="fw-bold mb-3" style="line-height: 1.3;">

                <%= sub.subject_name %>

              </h4>

              <!-- Divider -->
              <hr class="my-3">

              <!-- Actions -->
              <div class="mt-auto">

                <div class="d-grid gap-2">

                  <!-- Attendance -->
                  <a
                    href="/teacher/attendance/<%= sub.id %>"
                    class="btn btn-warning rounded-pill fw-semibold"
                  >

                    <i class="fa-solid fa-calendar-check me-2"></i>

                    Manage Attendance

                  </a>

                  <!-- Marks -->
                  <a
                    href="/teacher/marks/<%= sub.id %>"
                    class="btn btn-success rounded-pill fw-semibold"
                  >

                    <i class="fa-solid fa-file-pen me-2"></i>

                    Manage Marks

                  </a>

                </div>

              </div>

            </div>

          </div>

        </div>

      <% }) %>

    </div>

  <% } %>

</div>

<style>

.subject-card {
  transition: all 0.25s ease;
}

.subject-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 18px 40px rgba(0,0,0,0.08) !important;
}

</style>