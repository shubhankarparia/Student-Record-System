<!-- views/index.ejs -->

<div class="container-fluid bg-light min-vh-100">

  <!-- HERO SECTION -->
  <section class="py-5">

    <div class="row align-items-center g-5">

      <!-- Left Content -->
      <div class="col-lg-6">

        <div class="pe-lg-5">

          <span class="badge rounded-pill px-4 py-2 mb-3"
            style="
              background: linear-gradient(135deg, #4f46e5, #7c3aed);
              color: white;
              font-size: 0.9rem;
              letter-spacing: 0.5px;
            "
          >
            Student Record Management System
          </span>

          <h1 class="display-4 fw-bold mb-4 text-dark">

            Manage Student Records

            <span
              style="
                background: linear-gradient(135deg, #4f46e5, #7c3aed);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
              "
            >
              Easily & Securely
            </span>

          </h1>

          <p class="lead text-secondary mb-4" style="line-height: 1.8;">

            A complete digital platform to manage students, teachers,
            courses, attendance, grades, and academic records in one place.

          </p>

          <div class="d-flex flex-wrap gap-3">

            <a
              href="/login"
              class="btn btn-lg rounded-pill px-4 py-3 shadow-sm"
              style="
                background: linear-gradient(135deg, #4f46e5, #7c3aed);
                color: white;
                border: none;
              "
            >

              <i class="fa-solid fa-right-to-bracket me-2"></i>

              Access Dashboard

            </a>

            <a
              href="#features"
              class="btn btn-outline-dark btn-lg rounded-pill px-4 py-3"
            >

              <i class="fa-solid fa-circle-info me-2"></i>

              Explore Features

            </a>

          </div>

        </div>

      </div>

      <!-- Right Image -->
      <div class="col-lg-6 text-center">

        <img
          src="https://illustrations.popsy.co/amber/student-going-to-school.svg"
          alt="Student Illustration"
          class="img-fluid"
          style="
            max-height: 460px;
            filter: drop-shadow(0px 15px 25px rgba(0,0,0,0.15));
          "
        >

      </div>

    </div>

  </section>

  <!-- FEATURES SECTION -->
  <section id="features" class="py-5">

    <div class="text-center mb-5">

      <h2 class="fw-bold text-dark">

        Powerful System Features

      </h2>

      <p class="text-secondary fs-5">

        Everything needed to run a modern academic institution.

      </p>

    </div>

    <div class="row g-4">

      <!-- Feature 1 -->
      <div class="col-md-4">

        <div
          class="card border-0 rounded-4 h-100 shadow-sm"
          style="
            background: linear-gradient(135deg, #eef2ff, #ffffff);
            transition: 0.3s;
          "
        >

          <div class="card-body text-center p-5">

            <div
              class="d-flex align-items-center justify-content-center rounded-circle mx-auto mb-4"
              style="
                width: 85px;
                height: 85px;
                background: rgba(79, 70, 229, 0.12);
              "
            >

              <i class="fa-solid fa-users fa-2x text-primary"></i>

            </div>

            <h4 class="fw-bold mb-3 text-dark">

              Centralized Records

            </h4>

            <p class="text-secondary mb-0">

              Manage students, teachers, courses, and academic information
              from one centralized system dashboard.

            </p>

          </div>

        </div>

      </div>

      <!-- Feature 2 -->
      <div class="col-md-4">

        <div
          class="card border-0 rounded-4 h-100 shadow-sm"
          style="
            background: linear-gradient(135deg, #ecfdf5, #ffffff);
            transition: 0.3s;
          "
        >

          <div class="card-body text-center p-5">

            <div
              class="d-flex align-items-center justify-content-center rounded-circle mx-auto mb-4"
              style="
                width: 85px;
                height: 85px;
                background: rgba(16, 185, 129, 0.12);
              "
            >

              <i class="fa-solid fa-chart-line fa-2x text-success"></i>

            </div>

            <h4 class="fw-bold mb-3 text-dark">

              Performance Tracking

            </h4>

            <p class="text-secondary mb-0">

              Track marks, attendance, student progress,
              and performance reports in real time.

            </p>

          </div>

        </div>

      </div>

      <!-- Feature 3 -->
      <div class="col-md-4">

        <div
          class="card border-0 rounded-4 h-100 shadow-sm"
          style="
            background: linear-gradient(135deg, #fff7ed, #ffffff);
            transition: 0.3s;
          "
        >

          <div class="card-body text-center p-5">

            <div
              class="d-flex align-items-center justify-content-center rounded-circle mx-auto mb-4"
              style="
                width: 85px;
                height: 85px;
                background: rgba(245, 158, 11, 0.12);
              "
            >

              <i class="fa-solid fa-shield-halved fa-2x text-warning"></i>

            </div>

            <h4 class="fw-bold mb-3 text-dark">

              Secure Authentication

            </h4>

            <p class="text-secondary mb-0">

              Role-based access control for Admin,
              Teacher, and Student panels with secure login.

            </p>

          </div>

        </div>

      </div>

    </div>

  </section>

  <!-- QUICK ACCESS SECTION -->
  <section class="py-5">

    <div
      class="card border-0 rounded-4 overflow-hidden shadow-lg"
      style="
        background: linear-gradient(135deg, #ffffff, #f8fafc);
      "
    >

      <div class="row g-0 align-items-center">

        <!-- Left -->
        <div class="col-lg-7 p-5">

          <h2 class="fw-bold mb-3 text-dark">

            Start Managing Academic Records Today

          </h2>

          <p class="text-secondary mb-4 fs-5">

            Access the system dashboard to manage courses,
            register students, assign teachers, monitor attendance,
            and generate academic reports efficiently.

          </p>

          <a
            href="/login"
            class="btn btn-lg rounded-pill px-4 py-3 shadow-sm"
            style="
              background: linear-gradient(135deg, #4f46e5, #7c3aed);
              color: white;
              border: none;
            "
          >

            Login to Continue

            <i class="fa-solid fa-arrow-right ms-2"></i>

          </a>

        </div>

        <!-- Right -->
        <div
          class="col-lg-5 p-5"
          style="
            background: linear-gradient(135deg, #eef2ff, #f8fafc);
          "
        >

          <div class="row g-4">

            <div class="col-6">

              <div class="card border-0 rounded-4 shadow-sm p-4 text-center">

                <i class="fa-solid fa-user-graduate fa-2x text-primary mb-3"></i>

                <h5 class="fw-bold text-dark">Students</h5>

                <p class="small text-secondary mb-0">
                  Student Profiles
                </p>

              </div>

            </div>

            <div class="col-6">

              <div class="card border-0 rounded-4 shadow-sm p-4 text-center">

                <i class="fa-solid fa-book fa-2x text-success mb-3"></i>

                <h5 class="fw-bold text-dark">Courses</h5>

                <p class="small text-secondary mb-0">
                  Course Management
                </p>

              </div>

            </div>

            <div class="col-6">

              <div class="card border-0 rounded-4 shadow-sm p-4 text-center">

                <i class="fa-solid fa-chalkboard-user fa-2x text-warning mb-3"></i>

                <h5 class="fw-bold text-dark">Teachers</h5>

                <p class="small text-secondary mb-0">
                  Faculty Management
                </p>

              </div>

            </div>

            <div class="col-6">

              <div class="card border-0 rounded-4 shadow-sm p-4 text-center">

                <i class="fa-solid fa-chart-column fa-2x text-danger mb-3"></i>

                <h5 class="fw-bold text-dark">Analytics</h5>

                <p class="small text-secondary mb-0">
                  Reports & Charts
                </p>

              </div>

            </div>

          </div>

        </div>

      </div>

    </div>

  </section>

</div>