<!-- views/admin/students.ejs -->

<div class="container-fluid">

  <!-- Page Header -->
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">

    <div>
      <h2 class="fw-bold mb-1">
        <i class="fa-solid fa-user-graduate text-primary me-2"></i>
        Manage Students
      </h2>

      <p class="text-muted mb-0">
        Enroll students, manage academic records, and configure portal access.
      </p>
    </div>

    <a href="/admin/dashboard" class="btn btn-secondary rounded-pill">
      <i class="fa-solid fa-arrow-left"></i>
      Back to Dashboard
    </a>

  </div>

  <!-- Alerts -->
  <% if (typeof success !== 'undefined' && success) { %>

    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="fa-solid fa-circle-check me-2"></i>
      <%= success %>

      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

  <% } %>

  <% if (typeof error !== 'undefined' && error) { %>

    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="fa-solid fa-circle-exclamation me-2"></i>
      <%= error %>

      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>

  <% } %>

  <!-- Main Grid -->
  <div class="row g-4">

    <!-- LEFT COLUMN -->
    <div class="col-lg-5">

      <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-4">

          <h4 class="fw-bold mb-4">
            <i class="fa-solid fa-user-plus text-primary me-2"></i>
            Enroll New Student
          </h4>

          <form action="/admin/students/add" method="POST">

            <!-- Personal Information -->
            <div class="mb-4">

              <h6 class="text-uppercase fw-bold text-primary border-bottom pb-2 mb-3">
                Personal Information
              </h6>

              <!-- Full Name -->
              <div class="mb-3">

                <label class="form-label fw-semibold">
                  Full Name
                </label>

                <input
                  type="text"
                  name="name"
                  class="form-control"
                  placeholder="Enter student full name"
                  required
                >

              </div>

              <!-- Email -->
              <div class="mb-3">

                <label class="form-label fw-semibold">
                  Email Address
                </label>

                <input
                  type="email"
                  name="email"
                  class="form-control"
                  placeholder="student@email.com"
                  required
                >

              </div>

              <!-- Phone -->
              <div class="mb-3">

                <label class="form-label fw-semibold">
                  Phone Number
                </label>

                <input
                  type="text"
                  name="phone"
                  class="form-control"
                  placeholder="+91 9876543210"
                >

              </div>

              <!-- DOB + Gender -->
              <div class="row">

                <div class="col-md-6 mb-3">

                  <label class="form-label fw-semibold">
                    Date of Birth
                  </label>

                  <input
                    type="date"
                    name="dob"
                    class="form-control"
                  >

                </div>

                <div class="col-md-6 mb-3">

                  <label class="form-label fw-semibold">
                    Gender
                  </label>

                  <select name="gender" class="form-select">

                    <option value="">
                      Select Gender
                    </option>

                    <option value="Male">
                      Male
                    </option>

                    <option value="Female">
                      Female
                    </option>

                    <option value="Other">
                      Other
                    </option>

                  </select>

                </div>

              </div>

              <!-- Address -->
              <div class="mb-3">

                <label class="form-label fw-semibold">
                  Address
                </label>

                <textarea
                  name="address"
                  rows="3"
                  class="form-control"
                  placeholder="Enter full address"
                ></textarea>

              </div>

              <!-- Course -->
              <div class="mb-3">

                <label class="form-label fw-semibold">
                  Academic Course
                </label>

                <select
                  name="course_id"
                  class="form-select"
                  required
                >

                  <option value="">
                    Select Course
                  </option>

                  <% courses.forEach(course => { %>

                    <option value="<%= course.id %>">

                      <%= course.course_name %>
                      (
                      <%= course.course_code %>
                      )

                    </option>

                  <% }) %>

                </select>

              </div>

            </div>

            <!-- Portal Credentials -->
            <div class="mb-4">

              <h6 class="text-uppercase fw-bold text-primary border-bottom pb-2 mb-3">
                Portal Credentials
              </h6>

              <!-- Username -->
              <div class="mb-3">

                <label class="form-label fw-semibold">
                  Username
                </label>

                <input
                  type="text"
                  name="username"
                  class="form-control"
                  placeholder="Portal username"
                  required
                >

              </div>

              <!-- Password -->
              <div class="mb-4">

                <label class="form-label fw-semibold">
                  Password
                </label>

                <input
                  type="password"
                  name="password"
                  class="form-control"
                  placeholder="Create secure password"
                  required
                >

              </div>

            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-primary w-100 py-2 rounded-pill fw-semibold">

              Enroll Student

              <i class="fa-solid fa-arrow-right ms-2"></i>

            </button>

          </form>

        </div>

      </div>

    </div>

    <!-- RIGHT COLUMN -->
    <div class="col-lg-7">

      <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-4">

          <!-- Title -->
          <div class="d-flex justify-content-between align-items-center mb-4">

            <h4 class="fw-bold mb-0">
              <i class="fa-solid fa-users text-success me-2"></i>
              Registered Students
            </h4>

            <span class="badge bg-primary rounded-pill px-3 py-2">
              <%= students.length %> Students
            </span>

          </div>

          <!-- Empty State -->
          <% if (students.length === 0) { %>

            <div class="text-center py-5">

              <i class="fa-solid fa-user-slash fa-4x text-muted mb-3"></i>

              <h5 class="text-muted">
                No Students Found
              </h5>

              <p class="text-muted">
                Student records will appear here after enrollment.
              </p>

            </div>

          <% } else { %>

            <!-- Student Table -->
            <div class="table-responsive">

              <table class="table align-middle table-hover">

                <thead class="table-light">

                  <tr>

                    <th>
                      Student Information
                    </th>

                    <th>
                      Course
                    </th>

                    <th>
                      Gender
                    </th>

                    <th>
                      DOB
                    </th>

                    <th class="text-end">
                      Action
                    </th>

                  </tr>

                </thead>

                <tbody>

                  <% students.forEach(student => { %>

                    <tr>

                      <!-- Student Info -->
                      <td>

                        <div class="fw-semibold">

                          <%= student.name %>

                        </div>

                        <div class="small text-muted">

                          <i class="fa-solid fa-envelope"></i>

                          <%= student.email %>

                        </div>

                        <% if (student.phone) { %>

                          <div class="small text-muted">

                            <i class="fa-solid fa-phone"></i>

                            <%= student.phone %>

                          </div>

                        <% } %>

                        <div class="small mt-1">

                          <span class="badge bg-dark">

                            <i class="fa-solid fa-user"></i>

                            <%= student.username %>

                          </span>

                        </div>

                      </td>

                      <!-- Course -->
                      <td>

                        <% if (student.course_name) { %>

                          <span class="badge bg-info text-dark">

                            <%= student.course_name %>

                          </span>

                        <% } else { %>

                          <span class="text-muted">
                            Not Assigned
                          </span>

                        <% } %>

                      </td>

                      <!-- Gender -->
                      <td>

                        <% if (student.gender) { %>

                          <span class="badge bg-secondary">

                            <%= student.gender %>

                          </span>

                        <% } else { %>

                          <span class="text-muted">
                            N/A
                          </span>

                        <% } %>

                      </td>

                      <!-- DOB -->
                      <td>

                        <span class="small">

                          <%= student.dob || 'N/A' %>

                        </span>

                      </td>

                      <!-- Actions -->
                      <td class="text-end">

                        <form
                          action="/admin/students/delete/<%= student.id %>"
                          method="POST"
                          onsubmit="return confirm('Are you sure you want to delete this student?');"
                        >

                          <button
                            type="submit"
                            class="btn btn-danger btn-sm rounded-pill"
                          >

                            <i class="fa-solid fa-trash"></i>

                          </button>

                        </form>

                      </td>

                    </tr>

                  <% }) %>

                </tbody>

              </table>

            </div>

          <% } %>

        </div>

      </div>

    </div>

  </div>

</div>