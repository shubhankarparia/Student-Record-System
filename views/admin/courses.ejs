<!-- views/admin/courses.ejs -->

<div class="container-fluid">

  <!-- Page Header -->
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">

    <div>

      <h2 class="fw-bold mb-1">

        <i class="fa-solid fa-book text-primary me-2"></i>

        Manage Courses

      </h2>

      <p class="text-muted mb-0">

        Create and manage academic course programs.

      </p>

    </div>

    <a href="/admin/dashboard" class="btn btn-secondary rounded-pill">

      <i class="fa-solid fa-arrow-left"></i>

      Back to Dashboard

    </a>

  </div>

  <!-- Success Alert -->
  <% if (typeof success !== 'undefined' && success) { %>

    <div class="alert alert-success alert-dismissible fade show" role="alert">

      <i class="fa-solid fa-circle-check me-2"></i>

      <%= success %>

      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>

    </div>

  <% } %>

  <!-- Error Alert -->
  <% if (typeof error !== 'undefined' && error) { %>

    <div class="alert alert-danger alert-dismissible fade show" role="alert">

      <i class="fa-solid fa-circle-exclamation me-2"></i>

      <%= error %>

      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>

    </div>

  <% } %>

  <!-- Main Grid -->
  <div class="row g-4">

    <!-- LEFT SIDE -->
    <div class="col-lg-4">

      <!-- Add Course Card -->
      <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-4">

          <h4 class="fw-bold mb-4">

            <i class="fa-solid fa-plus-circle text-primary me-2"></i>

            Add New Course

          </h4>

          <form action="/admin/courses/add" method="POST">

            <!-- Course Name -->
            <div class="mb-3">

              <label class="form-label fw-semibold">
                Course Name
              </label>

              <input
                type="text"
                name="course_name"
                class="form-control"
                placeholder="e.g. Bachelor of Science"
                required
              >

            </div>

            <!-- Course Code -->
            <div class="mb-3">

              <label class="form-label fw-semibold">
                Course Code
              </label>

              <input
                type="text"
                name="course_code"
                class="form-control"
                placeholder="e.g. BSC101"
                required
              >

            </div>

            <!-- Duration -->
            <div class="mb-4">

              <label class="form-label fw-semibold">
                Duration
              </label>

              <input
                type="text"
                name="duration"
                class="form-control"
                placeholder="e.g. 4 Years"
                required
              >

            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="btn btn-primary w-100 py-2 rounded-pill fw-semibold"
            >

              Register Course

              <i class="fa-solid fa-arrow-right ms-2"></i>

            </button>

          </form>

        </div>

      </div>

    </div>

    <!-- RIGHT SIDE -->
    <div class="col-lg-8">

      <!-- Course Directory -->
      <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-4">

          <!-- Title -->
          <div class="d-flex justify-content-between align-items-center mb-4">

            <h4 class="fw-bold mb-0">

              <i class="fa-solid fa-table-list text-success me-2"></i>

              Course Directory

            </h4>

            <span class="badge bg-primary rounded-pill px-3 py-2">

              <%= courses.length %> Courses

            </span>

          </div>

          <!-- Empty State -->
          <% if (courses.length === 0) { %>

            <div class="text-center py-5">

              <i class="fa-solid fa-folder-open fa-4x text-muted mb-3"></i>

              <h5 class="text-muted">
                No Courses Found
              </h5>

              <p class="text-muted">
                Courses will appear here after registration.
              </p>

            </div>

          <% } else { %>

            <!-- Table -->
            <div class="table-responsive">

              <table class="table table-hover align-middle">

                <thead class="table-light">

                  <tr>

                    <th>
                      Course Code
                    </th>

                    <th>
                      Course Name
                    </th>

                    <th>
                      Duration
                    </th>

                    <th class="text-end">
                      Action
                    </th>

                  </tr>

                </thead>

                <tbody>

                  <% courses.forEach(course => { %>

                    <tr>

                      <!-- Code -->
                      <td>

                        <span class="badge bg-info text-dark px-3 py-2">

                          <%= course.course_code %>

                        </span>

                      </td>

                      <!-- Name -->
                      <td class="fw-semibold">

                        <%= course.course_name %>

                      </td>

                      <!-- Duration -->
                      <td>

                        <span class="badge bg-secondary">

                          <%= course.duration %>

                        </span>

                      </td>

                      <!-- Action -->
                      <td class="text-end">

                        <form
                          action="/admin/courses/delete/<%= course.id %>"
                          method="POST"
                          onsubmit="return confirm('Are you sure you want to delete this course?');"
                        >

                          <button
                            type="submit"
                            class="btn btn-danger btn-sm rounded-pill"
                          >

                            <i class="fa-solid fa-trash"></i>

                          </button>

                        </form>

                      </td>

                    </tr>

                  <% }) %>

                </tbody>

              </table>

            </div>

          <% } %>

        </div>

      </div>

    </div>

  </div>

</div>